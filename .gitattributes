# Default: auto-detect text files and normalize to LF in the repo.
* text=auto

# Keep repo metadata and docs LF.
*.md text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

# Windows project, resource, and script files use CRLF on checkout.
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf
*.sln text eol=crlf
*.slnx text eol=crlf
*.rc text eol=crlf
*.rc2 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.ps1xml text eol=crlf
